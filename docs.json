{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PolyX",
  "colors": {
    "primary": "#E1FF01",
    "light": "#E1FF01",
    "dark": "#E1FF01"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "gettingstarted"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Trade",
        "href": "https://t.me/polyxcopy_bot"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "favicon": {
    "light": "/images/LOGOPOLYX.svg",
    "dark": "/images/LOGOPOLYX.svg"
  },
  "appearance": {
    "strict": false,
    "default": "dark"
  },
  "banner": {
    "content": "Trade"
  },
  "thumbnails": {
    "appearance": "dark",
    "background": "/images/LOGOPOLYX.svg",
    "fonts": {
      "family": "Inter"
    }
  },
  "styling": {
    "codeblocks": "dark",
    "latex": false
  }
}
