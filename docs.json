{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PolyX",
  "colors": {
    "primary": "#E1FF01",
    "light": "#E1FF01",
    "dark": "#E1FF01"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "introduction",
          "quickstart"
        ]
      }
    ]
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Trade",
      "href": "https://t.me/polyxcopy_bot"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "favicon": "/images/LOGOPOLYX.svg",
  "logo": "/images/LOGOPOLYX.svg",
  "errors": {
    "404": {
      "redirect": true
    }
  },
  "thumbnails": {
    "appearance": "dark",
    "background": "/images/LOGOPOLYX.svg"
  },
  "styling": {
    "codeblocks": "dark"
  },
  "icons": {
    "library": "fontawesome"
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": true
  },
  "banner": {
    "dismissible": false
  }
}